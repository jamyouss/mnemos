# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# Embedding
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Paths (local mode)
CODEBASE_PATH=/data/codebase
CLAUDE_CONFIG_PATH=/data/claude-config

# Watcher
WATCHER_DEBOUNCE_MS=2000
WATCHER_IGNORE=node_modules,vendor,.git,dist,build,.nuxt,.output,__pycache__

# Deployed mode
MNEMOS_MODE=local
MNEMOS_AUTH_ENABLED=false

# LLM provider — used for memory extraction, dedup merge, contextual chunking, grader, rewriter.
# One of: ollama | anthropic | openai
MNEMOS_LLM_PROVIDER=ollama

# Model name (provider-specific):
#   ollama:     llama3.1:8b, qwen2.5:7b, mistral, …
#   anthropic:  claude-opus-4-7, claude-sonnet-4-6, claude-haiku-4-5
#   openai:     gpt-4o, gpt-4o-mini, or model name on a compatible endpoint
MNEMOS_LLM_MODEL=llama3.1:8b

# API key for anthropic / openai (leave blank for ollama)
MNEMOS_LLM_API_KEY=

# Generic base URL (overrides defaults). Useful for vLLM, LM Studio, Together, Groq, OpenRouter, etc.
# Leave blank to use provider defaults.
MNEMOS_LLM_BASE_URL=

# Backwards-compatible ollama-only URL (ignored when MNEMOS_LLM_BASE_URL is set)
MNEMOS_OLLAMA_URL=http://ollama:11434

# Deduplication
MNEMOS_DEDUP_THRESHOLD=0.85
MNEMOS_DEDUP_STRATEGY=merge

# Contextual retrieval (Phase 2A.2 — Anthropic-style preamble per chunk via LLM)
MNEMOS_CONTEXTUAL_ENABLED=false
MNEMOS_CONTEXTUAL_WORKERS=4

# Cross-encoder reranker (Phase 2B — boost precision ~+9 MRR / +25-40% precision)
# Default model: BAAI/bge-reranker-base (~280MB). For higher quality use bge-reranker-v2-m3 (~568MB).
MNEMOS_RERANKER_ENABLED=false
MNEMOS_RERANKER_MODEL=BAAI/bge-reranker-base
MNEMOS_RERANKER_TYPE=cross-encoder

# MMR diversification (applies after reranking; only useful when reranker returns >> limit results)
MNEMOS_MMR_ENABLED=false
MNEMOS_MMR_LAMBDA=0.5

# Memory
MAX_DOCUMENTS=0  # 0 = unlimited
