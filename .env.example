# Mnemos — full environment variable reference.
#
# Two entry points depending on how much you need:
#
#   * .env.minimal.example  — 5 vars, get started in 5 minutes
#   * .env.example          — this file, every knob documented
#
# Copy whichever you want into `.env` and tweak from there. Sections are
# ordered from "you'll always touch this" to "leave it alone unless you
# really know what you want".

# ============================================================================
# === Starter — minimum required for a working install
# ============================================================================

# Where Mnemos finds your code on the host. Default = the empty ./data/codebase
# dir in the repo, which is useless until you point it somewhere real.
#   MNEMOS_CODEBASE_HOST_PATH=~/code
#   MNEMOS_CODEBASE_HOST_PATH=/srv/projects
MNEMOS_CODEBASE_HOST_PATH=./data/codebase
MNEMOS_CLAUDE_CONFIG_HOST_PATH=./data/claude-config

# LLM provider (`ollama` | `anthropic` | `openai`). The default Ollama
# setup works locally with no API key. Switch to a cloud provider for
# faster / higher-quality memory extraction and CRAG features.
MNEMOS_LLM_PROVIDER=ollama

# Model name (provider-specific):
#   ollama:     llama3.1:8b, qwen2.5:7b, mistral, …
#   anthropic:  claude-opus-4-7, claude-sonnet-4-6, claude-haiku-4-5
#   openai:     gpt-4o, gpt-4o-mini, or any model on a compatible endpoint
MNEMOS_LLM_MODEL=llama3.1:8b

# API key for anthropic / openai (leave blank for ollama)
MNEMOS_LLM_API_KEY=

# Image tags — usually leave these alone. Override to pin a specific version.
MNEMOS_SERVER_IMAGE=jamyouss/mnemos-server:latest
MNEMOS_WATCHER_IMAGE=jamyouss/mnemos-watcher:latest

# ============================================================================
# === Production — multi-tenant deployment + observability
# ============================================================================

# `local` = single-tenant, no auth, dev mode
# `deployed` = multi-tenant, requires Authorization: Bearer <api-key>
MNEMOS_MODE=local
MNEMOS_AUTH_ENABLED=false

# Append every retrieval call to a JSONL log. Useful for debugging,
# replay, and A/B comparisons in production. Defaults to /data/state/.
MNEMOS_QUERY_LOG_ENABLED=false
MNEMOS_QUERY_LOG_PATH=/data/state/query-log.jsonl

# Maximum documents per tenant (0 = unlimited). Only enforced in deployed mode.
MAX_DOCUMENTS=0

# ============================================================================
# === Advanced — retrieval-quality knobs
# ============================================================================
#
# Every flag below is OFF by default. Each one trades some latency for
# precision/recall — read docs/RETRIEVAL_PIPELINE.md before flipping them in
# production. The reranker is the biggest quality lever; the others compose
# on top of it.

# --- Cross-encoder reranker --------------------------------------------------
# +~9 MRR points / +25–40 % precision. Slow on CPU (~10 s/query with bge-base),
# fast on GPU (~250 ms). Use ms-marco-MiniLM-L-6-v2 for a 3× speedup on CPU.
MNEMOS_RERANKER_ENABLED=false
MNEMOS_RERANKER_MODEL=BAAI/bge-reranker-base
MNEMOS_RERANKER_TYPE=cross-encoder

# MMR diversification (post-rerank — picks novel candidates for the top-K)
MNEMOS_MMR_ENABLED=false
MNEMOS_MMR_LAMBDA=0.5

# --- CRAG corrective loop ---------------------------------------------------
# Grader scores each retrieved chunk via the LLM; if every chunk scores
# `low`, the rewriter generates query variants and we retry retrieval.
# Pair with a fast LLM (Anthropic Haiku, Groq) — every chunk = one LLM call.
MNEMOS_GRADER_ENABLED=false
MNEMOS_GRADER_WORKERS=4
MNEMOS_REWRITER_ENABLED=false
MNEMOS_REWRITER_STRATEGY=expansion   # expansion | decompose | hyde
MNEMOS_REWRITER_MAX_VARIANTS=3

# --- Semantic router --------------------------------------------------------
# Trims target collections per query via cosine sim against each
# collection's description. Cheap, useful when you have many collections.
MNEMOS_ROUTER_ENABLED=false
MNEMOS_ROUTER_TOP_K=2
MNEMOS_ROUTER_MIN_SCORE=0.4

# --- Semantic cache ---------------------------------------------------------
# Cosine-similarity cache. Replays results for queries close enough to
# something already seen (default threshold 0.95). Invalidated on reindex.
MNEMOS_CACHE_ENABLED=false
MNEMOS_CACHE_THRESHOLD=0.95
MNEMOS_CACHE_TTL_SECONDS=3600

# --- Contextual chunking (indexing-side) -----------------------------------
# Prepends an LLM-generated one-sentence preamble to every chunk before
# embedding. Anthropic reports -49 % retrieval failure rate. Expensive at
# index time — plan a maintenance window for the full reindex.
MNEMOS_CONTEXTUAL_ENABLED=false
MNEMOS_CONTEXTUAL_WORKERS=4

# --- Memory dedup -----------------------------------------------------------
# Cosine threshold above which incoming memories are merged into / replace
# an existing one. Strategy `merge` consolidates via LLM, `replace` overwrites.
MNEMOS_DEDUP_THRESHOLD=0.85
MNEMOS_DEDUP_STRATEGY=merge

# ============================================================================
# === Infrastructure — change only if you're tweaking the stack
# ============================================================================

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# Embedding model — change → must reindex (collection schema mismatch otherwise)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Container-side paths (host paths are MNEMOS_*_HOST_PATH above)
CODEBASE_PATH=/data/codebase
CLAUDE_CONFIG_PATH=/data/claude-config

# File watcher behaviour
WATCHER_DEBOUNCE_MS=2000
WATCHER_IGNORE=node_modules,vendor,.git,dist,build,.nuxt,.output,__pycache__

# Generic LLM base URL — overrides MNEMOS_OLLAMA_URL when set. Use this for
# OpenAI-compatible endpoints (vLLM, LM Studio, Groq, Together, OpenRouter…).
MNEMOS_LLM_BASE_URL=

# Ollama-only URL (ignored when MNEMOS_LLM_BASE_URL is set).
# Auto-detected when blank: bundled → host.docker.internal → localhost.
MNEMOS_OLLAMA_URL=

# Path → tags mapping — optional YAML declaring tags per path prefix.
# Leave default unless you want explicit tags; otherwise Mnemos falls back to
# cumulative path segments. See config/projects.example.yaml.
MNEMOS_PROJECTS_CONFIG_PATH=/app/config/projects.yaml
