# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# Embedding
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Paths (local mode)
CODEBASE_PATH=/data/codebase
CLAUDE_CONFIG_PATH=/data/claude-config

# Watcher
WATCHER_DEBOUNCE_MS=2000
WATCHER_IGNORE=node_modules,vendor,.git,dist,build,.nuxt,.output,__pycache__

# Deployed mode
RAG_MODE=local
RAG_AUTH_ENABLED=false

# Memory
MAX_DOCUMENTS=0  # 0 = unlimited
