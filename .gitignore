__pycache__/
*.pyc
*.egg-info/
dist/
build/
.env
.venv/
venv/
*.egg
.pytest_cache/
.DS_Store
.claude/
uv.lock

# Eval runs (generated artifacts)
evals/runs/*.json
evals/dataset/_candidates.yaml
# Your own golden set is local data, not source code. Keep only the example committed.
evals/dataset/golden.yaml
evals/dataset/golden.legacy-*.yaml

# User-mounted dirs — keep .gitkeep placeholders but ignore the rest
data/codebase/*
!data/codebase/.gitkeep
data/claude-config/*
!data/claude-config/.gitkeep
config/projects.yaml
