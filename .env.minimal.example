# Mnemos — minimal .env for the first 5 minutes.
#
# Copy to `.env` and adjust if needed:
#     cp .env.minimal.example .env
#
# 80% of users only ever need these. For the full surface (advanced retrieval
# features, observability, multi-tenant deployed mode, …) see .env.example.

# Where Mnemos finds your code on the host. Default mounts the empty
# ./data/codebase dir; point this at your real code root.
#   macOS / Linux examples:
#     MNEMOS_CODEBASE_HOST_PATH=~/code
#     MNEMOS_CODEBASE_HOST_PATH=/srv/projects
MNEMOS_CODEBASE_HOST_PATH=./data/codebase

# Where your Claude Code config lives (skills + docs to index).
# Leave as default if you don't use Claude Code.
MNEMOS_CLAUDE_CONFIG_HOST_PATH=./data/claude-config

# LLM provider used for memory extraction, dedup merge, and the optional
# CRAG features. The default `ollama` + local model works out of the box;
# swap to anthropic / openai for higher quality.
MNEMOS_LLM_PROVIDER=ollama
MNEMOS_LLM_MODEL=llama3.1:8b
